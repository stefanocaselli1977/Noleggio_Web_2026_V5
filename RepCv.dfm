      object QRRichText1: TQRRichText
        Left = 8
        Top = 432
        Width = 505
        Height = 137
        Frame.Color = clBlack
        Frame.DrawTop = False
        Frame.DrawBottom = False
        Frame.DrawLeft = False
        Frame.DrawRight = False
        Size.Values = (
          362.479166666667
          21.1666666666667
          1143
          1336.14583333333)
        Alignment = taLeftJustify
        AutoStretch = False
        Color = clWindow
        Font.Charset = DEFAULT_CHARSET
        Font.Color = clWindowText
        Font.Height = -9
        Font.Name = 'Arial'
        Font.Style = []
        Lines.Strings = (
          
            'Io sottoscritto, lascio il prodotto di mia prorpiet'#224', che ricono' +
            'sco nelle descrizioni soprastanti, '
          'in uso, custodia, e temporanea propriet'#224' di PARMASPORT S.r.l.'
          
            'PARMASPORT S.r.l potr'#224' utilizzare il prodotto come se fosse di s' +
            'ua propriet'#224' '
          
            'a tutti gli effetti, quindi potr'#224' noleggiarlo, testarlo, riparar' +
            'lo, e venderlo.'
          
            'Al momento della rivendica da parte del Ex proprietario, PARMASP' +
            'ORT S.r.l '
          
            'potr'#224' o rendere il prodotto senza dover nulla pi'#249' al proprietari' +
            'o, o remunerare lo stesso '
          
            'con la somma stipulata e sottoscritta al momento della firma di ' +
            'questo contratto, mediante il '
          
            'sistema scelto dallo stesso Ex Proprietario al momento della sti' +
            'pula. Nel caso in cui l'#39'Ex '
          
            'proprietario richieda di rientrare in possesso del prodotto e  e' +
            ' non si proceda alla liquidazione '
          
            'dell'#39'oggetto secondo la modalit'#224' descritta sopra, PARMASPORT S.r' +
            '.l si riserva 7gg di tempo '
          'per adempiere alla restituzione dell'#39'oggetto stesso.')
      end
