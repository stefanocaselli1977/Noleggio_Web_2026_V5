    object TabSheet13: TTabSheet
      Caption = 'TabSheet13'
      ImageIndex = 12
      TabVisible = False
      object RichEdit1: TRichEdit
        Left = 0
        Top = 160
        Width = 305
        Height = 233
        Font.Charset = ANSI_CHARSET
        Font.Color = clWindowText
        Font.Height = -11
        Font.Name = 'MS Sans Serif'
        Font.Style = []
        Lines.Strings = (
          'Salve Sig. ,in '
          'base alle '
          'informazioni '
          'presenti nel '
          'nostro '
          'Database,'
          'risulta che ha '
          'effettuato un '
          'noleggio il '
          'giorno __, per '
          'un '
          'totale '
          'di'
          'gg __, e avrebbe '
          'dovuto '
          'riconsegnare il '
          'materiale in data '
          '____.'
          'Ad oggi la sua '
          'posizione ci '
          'risulta ancora '
          'aperta, quindi se'
          'ancora non lo '
          'avesse fatto, la '
          'preghiamo di '
          'effettuare la '
          'riconsegna del'
          'mate'
          'riale quanto '
          'prima.'
          'Se '
          'contrariamente '
          'ha gi'#224' effettuato '
          'la riconsegna la '
          'preghiamo '
          'di'
          'contattarci per '
          'verificare '
          'l'#39'avvenuta '
          'riconsegna.'
          ''
          'Questo '
          'messaggio '#232' '
          'stato '
          'autogenerato '
          'dal software di '
          'vigilanza delle'
          'riconsegne.')
        ParentFont = False
        TabOrder = 0
      end
